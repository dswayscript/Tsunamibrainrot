-- Hàm load an toàn
local function SafeLoad(url, name)
    Rayfield:Notify({
        Title = "Đang mở hub",
        Content = name,
        Duration = 4
    })

    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if not success or not result or result == "" then
        Rayfield:Notify({
            Title = "Lỗi tải",
            Content = "Không lấy được script",
            Duration = 5
        })
        return
    end

    local runSuccess, err = pcall(function()
        loadstring(result)()
    end)

    if not runSuccess then
        Rayfield:Notify({
            Title = "Callback Error",
            Content = err,
            Duration = 6
        })
    end
end

